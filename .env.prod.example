# Production environment variables for SkillSwap
# Copy this file to .env.prod and fill in real values
# NEVER commit .env.prod to git

# PostgreSQL configuration
POSTGRES_USER=skillswap
POSTGRES_PASSWORD=use_a_strong_random_password_here
POSTGRES_DB=skillswap

# AWS Cognito configuration
# Get these from the AWS Cognito Console
COGNITO_REGION=us-west-1
COGNITO_USER_POOL_ID=us-west-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend configuration
NEXT_PUBLIC_API_URL=https://skillsswap.xyz/api

# Future: AWS Secrets Manager
# In a future step, these secrets can be moved to AWS Secrets Manager
# and fetched at runtime instead of stored in this file.
