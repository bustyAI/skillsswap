# PostgreSQL configuration
POSTGRES_USER=skillswap
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=skillswap

# Connection URLs (for application use)
DATABASE_URL=postgresql+asyncpg://skillswap:your_secure_password_here@localhost:5432/skillswap
REDIS_URL=redis://localhost:6379/0

# AWS Cognito configuration
# Get these from the AWS Cognito Console after creating your User Pool
COGNITO_REGION=us-west-2
COGNITO_USER_POOL_ID=us-west-2_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
